USE tcg_year1;

-- CALLS TABLE — captures every Exotel call
-- Without call_duration_sec we can never analyze call quality
-- Without ai_summary_status we can never track AI failures
CREATE TABLE IF NOT EXISTS schema_calls (
    call_id            INT PRIMARY KEY,
    client_id          INT         NOT NULL,
    lead_id            INT         NOT NULL,
    sales_exec_id      INT,
    call_start_time    DATETIME,
    call_duration_sec  INT,        -- MUST HAVE: for call quality analysis
    call_status        VARCHAR(20), -- Connected / Dropped / No_Answer
    exotel_call_sid    VARCHAR(60), -- MUST HAVE: for debugging Exotel issues
    ai_summary_status  VARCHAR(20), -- Success / Failed / Pending
    ai_summary_text    TEXT,
    pair_score         INT,         -- 0-100 AI confidence score
    created_at         DATETIME   DEFAULT NOW()
);

-- LEADS TABLE — every lead created in Sirrus.ai
CREATE TABLE IF NOT EXISTS schema_leads (
    lead_id        INT PRIMARY KEY,
    client_id      INT          NOT NULL,
    lead_source    VARCHAR(30),  -- Facebook / Google / Walk-in / Reference
    stage          VARCHAR(30),  -- New/Qualified/Site Visit/Opportunity/Closed
    assigned_to    INT,
    budget         BIGINT,       -- MUST HAVE: for segment analysis
    property_type  VARCHAR(20),
    final_outcome  VARCHAR(20),  -- Booked / Dropped / In-Progress
    created_at     DATETIME     DEFAULT NOW(),
    updated_at     DATETIME     ON UPDATE NOW()
);

-- USER LOGINS — tracks who logs into Sirrus.ai when
-- Without this we cannot detect churn risk in Year 2
CREATE TABLE IF NOT EXISTS schema_user_logins (
    login_id    INT PRIMARY KEY,
    client_id   INT          NOT NULL,
    user_id     INT          NOT NULL,
    login_time  DATETIME,
    device_type VARCHAR(20)  -- Mobile / Desktop / Tablet
);

-- FEATURE LOGS — tracks every button click inside the platform
-- Enables product analytics: which features are used, which are ignored
CREATE TABLE IF NOT EXISTS schema_feature_logs (
    log_id       INT PRIMARY KEY,
    client_id    INT          NOT NULL,
    user_id      INT,
    module       VARCHAR(30),  -- PreSales / Marketing / PostSales
    feature_name VARCHAR(60),  -- Add Lead / Generate Brochure / Post Update
    action       VARCHAR(20),  -- Created / Viewed / Updated / Deleted
    used_at      DATETIME     DEFAULT NOW()
);

